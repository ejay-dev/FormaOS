/* ─── Data ──────────────────────────────────────────────── */

interface ChangelogEntry {
  readonly version: string;
  readonly date: string;
  readonly tag: string;
  readonly tagColor: string;
  readonly title: string;
  readonly releaseName?: string;
  readonly items: readonly string[];
}

