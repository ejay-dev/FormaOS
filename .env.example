# =============================================================================
# FormaOS — Environment Configuration Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
#
# Variables marked [PUBLIC] are exposed to the browser (NEXT_PUBLIC_*).
# Variables marked [SECRET] must NEVER be exposed client-side.
# =============================================================================

# =============================================================================
# SUPABASE  (required)
# =============================================================================
# Get all three from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co          # [PUBLIC] Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                               # [PUBLIC] anon/public key — safe for browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                                   # [SECRET] bypasses RLS — server-only

# =============================================================================
# APPLICATION URLS  (required)
# =============================================================================
# Local dev: http://localhost:3000 — Production: set in Vercel to your real domains
NEXT_PUBLIC_APP_URL=http://localhost:3000                           # [PUBLIC] app domain (e.g. https://app.formaos.com.au)
NEXT_PUBLIC_SITE_URL=http://localhost:3000                          # [PUBLIC] marketing domain (e.g. https://www.formaos.com.au)
# NEXT_PUBLIC_COOKIE_DOMAIN=.formaos.com.au                        # [PUBLIC] optional — cookie domain for cross-subdomain auth (production only)

# =============================================================================
# FOUNDER / ADMIN ACCESS  (required)
# =============================================================================
# Grants admin panel access — use the email(s) you sign up with
FOUNDER_EMAILS=founder@example.com                                 # [SECRET] comma-separated list of admin emails
# FOUNDER_USER_IDS=uuid-1,uuid-2                                  # [SECRET] optional — Supabase user UUIDs for admin access
# FOUNDER_API_TOKEN=                                               # [SECRET] optional — bearer token for /api/health/detailed endpoint

# =============================================================================
# HEALTH ENDPOINT HARDENING  (recommended: always ON in production)
# =============================================================================
HEALTH_DETAILED_PROTECT=1                                          # [SECRET] 1=token-protected (default), 0=public (never in production)
HEALTH_DETAILED_FOUNDER_TOKEN=REPLACE_ME                           # [SECRET] required — random token for /api/health/detailed access
# HEALTH_DETAILED_INCLUDE_SYSTEM=0                                 # [SECRET] optional — set to 1 to include OS/memory info in health response

# =============================================================================
# STRIPE — BILLING  (required for billing)
# =============================================================================
# Get from Stripe Dashboard → Developers → API keys / Webhooks
# Use sk_test_* keys for development. Live keys only in Vercel.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME                               # [SECRET] Stripe secret API key
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME                             # [SECRET] Stripe webhook signing secret (Developers → Webhooks)
STRIPE_PRICE_BASIC=price_REPLACE_ME                                # [SECRET] Price ID for starter/basic plan (Products → Pricing)
STRIPE_PRICE_PRO=price_REPLACE_ME                                  # [SECRET] Price ID for pro plan
# STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME                         # [SECRET] optional — Price ID for enterprise plan
# STRIPE_PRICE_STARTER=price_REPLACE_ME                            # [SECRET] optional — alias for basic
# Alternative price ID env vars used by lib/billing/plans.ts:
# STRIPE_STARTER_PRICE_ID=price_REPLACE_ME                         # [SECRET] optional — overrides plan-level starter price
# STRIPE_PRO_PRICE_ID=price_REPLACE_ME                             # [SECRET] optional — overrides plan-level pro price
# STRIPE_ENTERPRISE_PRICE_ID=price_REPLACE_ME                      # [SECRET] optional — overrides plan-level enterprise price
# BILLING_AUTO_FIX=true                                            # [SECRET] optional — set to "false" to disable nightly billing reconciliation auto-fix

# =============================================================================
# RESEND — EMAIL  (required for transactional emails)
# =============================================================================
# Get from Resend Dashboard → API Keys
RESEND_API_KEY=re_REPLACE_ME                                       # [SECRET] Resend API key
RESEND_FROM_EMAIL=Formaos.team@gmail.com                           # [SECRET] sender "from" address for transactional emails
# RESEND_FROM_NAME=FormaOS                                         # [SECRET] optional — sender display name (default: "FormaOS")
# SUPPORT_EMAIL=Formaos.team@gmail.com                             # [SECRET] optional — support/contact inbox for auth emails
# NEXT_PUBLIC_CONTACT_EMAIL=Formaos.team@gmail.com                 # [PUBLIC] optional — marketing/footer contact address

# =============================================================================
# UPSTASH REDIS — CACHING  (optional, graceful fallback)
# =============================================================================
# Get from Upstash Console → Redis → your database → REST API
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io          # [SECRET]
# UPSTASH_REDIS_REST_TOKEN=REPLACE_ME                              # [SECRET]
# UPSTASH_REDIS_URL=rediss://default:password@host:6379            # [SECRET] optional — TCP URL for tools that need native Redis

# =============================================================================
# TRIGGER.DEV — BACKGROUND JOBS  (optional)
# =============================================================================
# Get from Trigger.dev Dashboard → Project Settings
# TRIGGER_PROJECT_REF=proj_yourproject                             # [SECRET] project reference ID
# TRIGGER_SECRET_KEY=tr_dev_REPLACE_ME                             # [SECRET] API secret key
# TRIGGER_API_URL=https://api.trigger.dev                          # [SECRET] optional — API endpoint override
# TRIGGER_APP_BASE_URL=https://app.formaos.com.au                  # [SECRET] optional — base URL for task callbacks
# TRIGGER_DEV_ENABLED=1                                            # [SECRET] optional — enable local Trigger execution in development
# TRIGGER_DISABLED=1                                               # [SECRET] optional — force Redis fallback even when Trigger is configured

# =============================================================================
# OPENTELEMETRY / TRACING  (optional)
# =============================================================================
# OTEL_SERVICE_NAME=formaos                                        # [SECRET] service name for traces
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-endpoint/v1/traces # [SECRET] OTLP collector endpoint
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>          # [SECRET] auth headers for OTLP exporter

# =============================================================================
# LANGFUSE — LLM OBSERVABILITY  (optional)
# =============================================================================
# Get from Langfuse Dashboard → Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME                             # [SECRET] Langfuse public key
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME                             # [SECRET] Langfuse secret key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com                     # [SECRET] optional — self-hosted Langfuse URL
# LANGFUSE_TRACING_ENVIRONMENT=development                         # [SECRET] optional — environment label for traces

# =============================================================================
# GOOGLE IDENTITY SERVICES  (required for Google OAuth branding)
# =============================================================================
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com  # [PUBLIC]

# =============================================================================
# SENTRY — ERROR MONITORING  (optional)
# =============================================================================
# Get DSN from Sentry Dashboard → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...                 # [PUBLIC] Sentry DSN — enables error tracking in production
# SENTRY_ORG=your-org-slug                                        # [SECRET] optional — Sentry org for source maps upload during build
# SENTRY_PROJECT=your-project-slug                                 # [SECRET] optional — Sentry project for source maps upload during build

# =============================================================================
# POSTHOG — PRODUCT ANALYTICS  (optional)
# =============================================================================
# Get from PostHog Dashboard → Project Settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_...                                  # [PUBLIC] PostHog project API key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com                 # [PUBLIC] PostHog instance URL (or your self-hosted URL)
# NEXT_PUBLIC_ANALYTICS_ENABLED=true                               # [PUBLIC] optional — force-enable analytics outside production

# =============================================================================
# CRON / AUTOMATION  (optional)
# =============================================================================
# Generate a random secret; used to authenticate Vercel Cron or external cron calls
# CRON_SECRET=REPLACE_ME                                           # [SECRET] bearer token for /api/cron/* endpoints

# =============================================================================
# AI  (optional)
# =============================================================================
# Get from OpenAI Dashboard → API Keys
# OPENAI_API_KEY=sk-...                                            # [SECRET] enables AI compliance assistant features

# =============================================================================
# SECURITY / TOKENS  (optional)
# =============================================================================
# EXPORT_TOKEN_SECRET=REPLACE_ME                                   # [SECRET] optional — signing secret for export download tokens (falls back to JWT_SECRET)
# JWT_SECRET=REPLACE_ME                                            # [SECRET] optional — fallback signing secret if EXPORT_TOKEN_SECRET is not set

# =============================================================================
# REPORT EXPORTS  (optional)
# =============================================================================
# REPORT_EXPORTS_BUCKET=report-exports                             # [SECRET] optional — Supabase storage bucket name (default: "report-exports")
# REPORT_EXPORTS_INLINE_PROCESSING=true                            # [SECRET] optional — set to "false" to skip inline processing of exports

# =============================================================================
# NOTIFICATIONS  (optional)
# =============================================================================
# DEFAULT_TIMEZONE=UTC                                             # [SECRET] optional — fallback timezone for digest notifications (default: "UTC")

# =============================================================================
# LOGGING  (optional)
# =============================================================================
# LOG_LEVEL=info                                                   # [SECRET] optional — server log level: debug, info, warn, error (default: debug in dev, info in prod)

# =============================================================================
# BRANDING  (optional)
# =============================================================================
# BRAND_OVERRIDE_ALLOW=false                                       # [SECRET] optional — set to "true" to allow runtime brand config overrides

# =============================================================================
# APP METADATA  (optional, typically set by CI/Vercel)
# =============================================================================
# NEXT_PUBLIC_APP_VERSION=1.0.0                                    # [PUBLIC] optional — shown in analytics events (default: "unknown")
